# --- Server ---
PORT=5000
NODE_ENV=production

# --- Database (PostgreSQL) ---
POSTGRES_URL=postgresql://user:password@host:5432/dbname
# Optional: provider CA certificate (PEM). When set, the DB connection verifies
# the server's TLS certificate (recommended; prevents MITM).
DB_CA_CERT=

# --- Auth ---
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=24h
# Used once by `node config/seed.js` to create the first admin. Do not commit real values.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_me_to_a_strong_password

# --- Cloudinary (media storage) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- Email (Resend) ---
RESEND_API_KEY=your_resend_api_key
NOTIFICATION_EMAIL=you@example.com

# --- WhatsApp notifications (CallMeBot, optional) ---
CALLMEBOT_API_KEY=

# --- AI assistant (Anthropic) ---
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- CORS: comma-separated list of allowed front-end origins ---
FRONTEND_URL=https://bookyeditingservices.vercel.app,https://www.bookyeditingservices.com
